<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>컴활 2급 필기 연습 - GitHub Pages</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;700&display=swap');
        body { font-family: 'Pretendard', sans-serif; background-color: #f3f4f6; }
        .card { height: 100%; display: flex; flex-direction: column; transition: transform 0.2s; }
        .selected-option { background-color: #3b82f6 !important; color: white !important; border-color: #2563eb !important; }
        .correct-answer { border: 2px solid #10b981 !important; background-color: #ecfdf5; }
        .wrong-answer { border: 2px solid #ef4444 !important; background-color: #fef2f2; }
    </style>
</head>
<body class="p-4 md:p-8">
    <div id="app" class="max-w-6xl mx-auto">
        <header class="mb-8 text-center">
            <h1 class="text-3xl font-bold text-blue-700">컴퓨터활용능력 2급 퀴즈</h1>
            <p class="text-gray-500 mt-2">GitHub Pages를 통한 온라인 문제풀이</p>
        </header>

        <div id="quiz-container">
            <div id="question-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Questions injected here -->
            </div>

            <div class="flex justify-between items-center mt-10 max-w-4xl mx-auto">
                <button id="prev-btn" onclick="changePage(-1)" class="px-6 py-2 bg-gray-400 text-white rounded-lg hover:bg-gray-500 disabled:opacity-50">이전</button>
                <span id="page-info" class="font-semibold text-lg text-gray-700">1 / 5</span>
                <button id="next-btn" onclick="changePage(1)" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">다음</button>
                <button id="submit-btn" onclick="gradeQuiz()" class="hidden px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 font-bold">채점하기</button>
            </div>
        </div>

        <div id="result-container" class="hidden text-center bg-white p-8 rounded-2xl shadow-xl mt-8 max-w-2xl mx-auto">
            <h2 class="text-4xl font-bold mb-4" id="score-display">00점</h2>
            <p class="text-xl mb-6 text-gray-600" id="result-message"></p>
            <div class="flex flex-col md:flex-row justify-center gap-4">
                <button onclick="restartQuiz(false)" class="px-8 py-3 bg-blue-600 text-white rounded-xl font-bold">처음부터 다시 풀기</button>
                <button id="review-wrong-btn" onclick="restartQuiz(true)" class="px-8 py-3 bg-red-500 text-white rounded-xl font-bold">틀린 문제만 다시 풀기</button>
            </div>
        </div>
    </div>

    <script>
        const allQuestions = [
            { id: 1, q: "다음 중 아래에서 설명하는 그래픽 기법은?", detail: "컴퓨터 프로그램을 이용하여 3차원 애니메이션을 만드는 과정으로 사물 모형에 명암과 색상을 추가하여 사실감을 더해주는 작업이다.", options: ["안티앨리어싱", "렌더링", "인터레이싱", "메조틴트"], answer: 1, explanation: "렌더링은 3차원 모델링에 명암과 색상을 입혀 사실감을 높이는 과정입니다." },
            { id: 2, q: "다음 중 JPEG 표준에 대한 설명으로 옳지 않은 것은?", options: ["주로 무손실 방식을 쓴다.", "jpg, jpeg 확장자를 사용한다.", "웹 상에서 사진 보관에 사용한다.", "고주파 성분 이미지 변환 시 품질이 낮다."], answer: 0, explanation: "JPEG는 주로 손실 압축 기법을 사용합니다." },
            { id: 3, q: "다음 중 컴퓨터 바이러스의 예방법으로 가장 거리가 먼 것은?", options: ["최신 백신 사용", "다운로드 파일 검사", "첨부파일을 다른 이름으로 저장 후 사용", "네트워크 공유 폴더 읽기 전용 지정"], answer: 2, explanation: "파일을 다른 이름으로 저장하는 것만으로는 바이러스 예방이 되지 않습니다." },
            { id: 4, q: "다음 중 네트워크 장비와 관련하여 라우터에 관한 설명으로 옳은 것은?", options: ["회선 통합 관리 장비", "최적의 IP 경로 설정 장비", "출입구 역할 장비", "도메인 네임 주소 변환 장비"], answer: 1, explanation: "라우터는 네트워크 사이에서 최적의 경로를 설정해줍니다." }
        ];

        // 20문제를 채우기 위한 루프
        for(let i=5; i<=20; i++) {
            allQuestions.push({
                id: i, q: `컴퓨터 일반 제 ${i}번 문제 (문제 데이터를 추가해 주세요)`, 
                options: ["보기 1", "보기 2", "보기 3", "보기 4"], 
                answer: 0,
                explanation: `${i}번 문제에 대한 해설입니다.`
            });
        }

        let currentQuestions = [...allQuestions];
        let userAnswers = {};
        let currentPage = 0;
        const questionsPerPage = 4;
        let isGraded = false;
        let wrongQuestions = [];

        function renderQuestions() {
            const list = document.getElementById('question-list');
            list.innerHTML = '';
            const start = currentPage * questionsPerPage;
            const end = start + questionsPerPage;
            const pageItems = currentQuestions.slice(start, end);

            pageItems.forEach((item) => {
                const card = document.createElement('div');
                card.className = `card bg-white p-6 rounded-xl shadow-sm border border-gray-200`;
                let optionsHtml = item.options.map((opt, oIdx) => {
                    let styleClass = "border border-gray-300";
                    if (userAnswers[item.id] === oIdx) styleClass = "selected-option";
                    if (isGraded) {
                        if (oIdx === item.answer) styleClass = "correct-answer font-bold text-green-700";
                        else if (userAnswers[item.id] === oIdx) styleClass = "wrong-answer text-red-700";
                    }
                    return `<button onclick="selectOption(${item.id}, ${oIdx})" ${isGraded ? 'disabled' : ''} class="w-full text-left p-3 rounded-lg mb-2 transition-all ${styleClass}">${oIdx + 1}. ${opt}</button>`;
                }).join('');

                let feedbackHtml = isGraded ? `<div class="mt-auto pt-4"><div class="p-4 rounded-lg ${userAnswers[item.id] === item.answer ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-800'}"><p class="font-bold">${userAnswers[item.id] === item.answer ? '✓ 정답' : '✗ 오답'}</p><p class="text-sm mt-1">정답: ${item.answer + 1}번 | ${item.explanation}</p></div></div>` : "";

                card.innerHTML = `<div class="mb-4"><span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-bold">Q${item.id}</span></div><h3 class="text-lg font-semibold mb-2">${item.q}</h3>${item.detail ? `<p class="bg-gray-50 p-3 text-xs text-gray-600 mb-4 border-l-4 border-blue-400 italic">${item.detail}</p>` : ''}<div class="flex-grow">${optionsHtml}</div>${feedbackHtml}`;
                list.appendChild(card);
            });
            updateNav();
        }

        function selectOption(qId, optionIdx) { userAnswers[qId] = optionIdx; renderQuestions(); }
        function changePage(dir) { currentPage += dir; window.scrollTo(0, 0); renderQuestions(); }
        function updateNav() {
            const totalPages = Math.ceil(currentQuestions.length / questionsPerPage);
            document.getElementById('page-info').innerText = `${currentPage + 1} / ${totalPages}`;
            document.getElementById('prev-btn').disabled = currentPage === 0;
            const isLastPage = currentPage === totalPages - 1;
            document.getElementById('next-btn').classList.toggle('hidden', isLastPage);
            document.getElementById('submit-btn').classList.toggle('hidden', !isLastPage || isGraded);
        }
        function gradeQuiz() {
            isGraded = true;
            let correctCount = 0; wrongQuestions = [];
            currentQuestions.forEach(q => { if (userAnswers[q.id] === q.answer) correctCount++; else wrongQuestions.push(q); });
            const score = Math.round((correctCount / currentQuestions.length) * 100);
            document.getElementById('quiz-container').classList.add('hidden');
            document.getElementById('result-container').classList.remove('hidden');
            document.getElementById('score-display').innerText = `${score}점`;
            document.getElementById('result-message').innerText = `${currentQuestions.length}문제 중 ${correctCount}문제를 맞혔습니다.`;
            document.getElementById('review-wrong-btn').style.display = wrongQuestions.length > 0 ? 'inline-block' : 'none';
        }
        function restartQuiz(onlyWrong = false) {
            currentQuestions = onlyWrong ? [...wrongQuestions] : [...allQuestions];
            userAnswers = {}; currentPage = 0; isGraded = false;
            document.getElementById('quiz-container').classList.remove('hidden');
            document.getElementById('result-container').classList.add('hidden');
            renderQuestions();
        }
        window.onload = renderQuestions;
    </script>
</body>
</html>